# ── Strategaize Blueprint Plattform — Production Environment ──────────
# Kopiere diese Datei als .env auf dem Hetzner-Server.
# Alle Werte MÜSSEN vor dem ersten Start gesetzt werden.

# === App ===
NEXT_PUBLIC_APP_URL=https://blueprint.strategaizetransition.com

# === Supabase — DUAL-URL-STRATEGIE (KRITISCH) ===
# Server-seitig (API Routes, Server Actions, Middleware):
#   → Interne Docker-URL via Kong. Darf NICHT die externe URL sein (Hairpin NAT).
SUPABASE_URL=http://supabase-kong:8000

# Browser-seitig (Client Components, NEXT_PUBLIC_*):
#   → Externe URL über Coolify/Caddy Reverse Proxy.
#   → Wird zur BUILD-TIME eingebettet. Muss beim Build verfügbar sein.
NEXT_PUBLIC_SUPABASE_URL=https://blueprint.strategaizetransition.com/supabase

# === JWT Keys ===
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERATE_ME_MIN_32_CHARS

# Anon Key und Service Role Key müssen als JWTs mit dem JWT_SECRET signiert werden.
# Generieren: node scripts/generate-secrets.mjs
NEXT_PUBLIC_SUPABASE_ANON_KEY=GENERATE_ME_SEE_DOCS
SUPABASE_SERVICE_ROLE_KEY=GENERATE_ME_SEE_DOCS

# === Database ===
POSTGRES_PASSWORD=GENERATE_ME_STRONG_PASSWORD

# === Realtime ===
# Generieren: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REALTIME_SECRET=GENERATE_ME_MIN_64_CHARS

# === SMTP (PFLICHT für Invite-Emails — ohne SMTP können keine User eingeladen werden) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@strategaizetransition.com

# === Error Alerts ===
# E-Mail-Adresse für Error-Benachrichtigungen (optional, default: SMTP_USER)
ERROR_ALERT_EMAIL=immo@bellaerts.de

# === Cron-Endpoint Secret (V4.2 SLC-048 — capture-reminders) ===
# Schützt /api/cron/capture-reminders vor unautorisiertem Aufruf.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUSS in Coolify gesetzt sein, BEVOR der erste Cron-Run erfolgt.
# Ohne Wert: Cron-Endpoint antwortet mit 503 (deaktiviert).
CRON_SECRET=GENERATE_ME_HEX_64

# === LLM (AWS Bedrock — Claude Sonnet 4.6 via eu-central-1 Frankfurt, DSGVO-konform) ===
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_REGION=eu-central-1
# LLM_MODEL=eu.anthropic.claude-sonnet-4-6-20250514-v1:0

# V8.1 LLM-Augmentation Modell-ID (DEC-175, separate von LLM_MODEL
# damit V8.1 unabhaengig von Light-Pipeline-Modell bleibt).
# Default ohne Setzen: anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_V8_1_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# === Whisper — Speech-to-Text (V2, lokal auf Hetzner, DSGVO-konform) ===
# Adapter-Pattern DEC-018. Optionen: local (self-hosted), azure (Azure Speech EU)
WHISPER_PROVIDER=local
WHISPER_URL=http://whisper:9000
WHISPER_MODEL=medium
# Feature-Flag: Mikrofon-Button im Questionnaire anzeigen (true/false)
NEXT_PUBLIC_WHISPER_ENABLED=true

# === Storage ===
# 200 MB pro Datei. Gesamtkapazität abhängig von Hetzner-Disk.
STORAGE_FILE_SIZE_LIMIT=209715200

# === Jitsi Meet — Video Conferencing (V3 Dialogue-Mode) ===
# Generieren: openssl rand -hex 32 (für APP_SECRET), openssl rand -hex 16 (für Passwörter)
JITSI_JWT_APP_ID=onboarding
JITSI_JWT_APP_SECRET=GENERATE_ME_HEX_64
JITSI_JICOFO_AUTH_PASSWORD=GENERATE_ME_HEX_32
JITSI_JICOFO_COMPONENT_SECRET=GENERATE_ME_HEX_32
JITSI_JVB_AUTH_PASSWORD=GENERATE_ME_HEX_32
JITSI_JIBRI_RECORDER_PASSWORD=GENERATE_ME_HEX_32
JITSI_JIBRI_XMPP_PASSWORD=GENERATE_ME_HEX_32
JITSI_DOMAIN=meet-onboarding.strategaizetransition.com

# === Jibri Recording Webhook (V3) ===
# Shared secret zwischen Jibri-finalize-Script und /api/dialogue/recording-ready.
# Generieren: openssl rand -hex 32
# Muss IDENTISCH im Jibri-finalize-Script (Header "Authorization: Bearer ${RECORDING_WEBHOOK_SECRET}")
# und in der App-ENV gesetzt sein. Ohne den Wert antwortet die Route mit HTTP 500.
RECORDING_WEBHOOK_SECRET=GENERATE_ME_HEX_64

# === Seed-User (SLC-002b) — Pflicht für ersten Deploy ===
# Liest scripts/seed-admin.mjs. Ausführung EINMAL nach Deploy:
#   docker exec <onboarding-app-container> npm run seed:admin
# Rotation siehe docs/RUNBOOK.md (supabase.auth.admin.updateUserById).
# Die Passwörter sind NICHT in der DB im Klartext — nur Bcrypt-Hash landet dort.
SEED_ADMIN_EMAIL=admin@strategaizetransition.com
SEED_ADMIN_PASSWORD=GENERATE_ME_STRONG_PASSWORD
SEED_DEMO_TENANT_ADMIN_EMAIL=demo-admin@strategaizetransition.com
SEED_DEMO_TENANT_ADMIN_PASSWORD=GENERATE_ME_STRONG_PASSWORD

# === V6.2 Compliance - Impressum-Stammdaten (DEC-116, FEAT-048) ===
# PFLICHT vor /deploy V6.2. Die Server-Component /impressum wirft Error
# bei fehlender Pflicht-ENV. Default-Werte nur fuer COMPANY und COUNTRY.
# Werte kommen aus Strategaize Transition BV (NL-Operativ).
# IMPRESSUM_VAT: NL-BTW-Nummer der Strategaize Transition BV. Real-Wert
# pending (siehe ISSUE-073). Bis zur Lieferung Platzhalter-String setzen
# damit /impressum nicht crasht. Sobald real-Wert vorliegt: Coolify-ENV
# updaten + Container-Reload (kein Code-Touch noetig).
IMPRESSUM_COMPANY=Strategaize Transition BV
IMPRESSUM_STREET=aan de Markt 19
IMPRESSUM_ZIP=6071 JD
IMPRESSUM_CITY=Swalmen
IMPRESSUM_COUNTRY=Niederlande
IMPRESSUM_KVK=42008238
IMPRESSUM_VAT=BTW-Nr. wird nachgereicht
IMPRESSUM_DIRECTOR=Heinrich Bellaerts
IMPRESSUM_EMAIL=bd@strategaizetransition.com

# === V7 Self-Signup (SLC-131..135 — FEAT-051 + FEAT-053) ===
# Shared Service-Key zwischen Intelligence-Studio (Caller) und Onboarding-Plattform (Callee).
# Per `feedback_env_value_not_command` direkt-Wert vom Agent geliefert; in BEIDE Coolify-Resources
# (Onboarding + Intelligence-Studio) IDENTISCH setzen. Bei Wechsel: openssl rand -hex 32 oder
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))".
# DEC-136 Service-Key-Rotation V7 = manuell-koordiniert.
PUBLIC_SIGNUP_SERVICE_KEY=GENERATE_ME_HEX_64

# Anti-Abuse: Komma-getrennte Wegwerf-Email-Domain-Liste, kein Whitespace. Onboarding-Resource only.
# Self-Signup-Endpoint /api/public/signup rejected Mails von diesen Domains mit 400.
PUBLIC_SIGNUP_BLOCKED_EMAIL_DOMAINS=mailinator.com,guerrillamail.com,tempmail.io,sharklasers.com,mvrht.com,trashmail.com,getairmail.com,maildrop.cc,yopmail.com,dispostable.com

# === V8.1 Lead-Conversion CTA (SLC-163 — FEAT-068) ===
# Empfaenger der Lead-Email beim Strategaize-Freigabe-CTA-Klick. Default-Wert
# kann fuer Internal-Test-Mode auf richard@bellaerts.de o.ae. umgesetzt werden.
STRATEGAIZE_BD_EMAIL=bd@strategaizetransition.de

# HMAC-SHA256-Secret fuer Magic-Link-Token (DEC-173 stateless). Pflicht-ENV —
# ohne Wert wirft generateCtaMagicLinkToken Error. Generation:
#   openssl rand -hex 64
# oder
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# In Coolify-Resource-ENV setzen, NICHT in das Repo-Template einchecken.
# Bei Rotation: alle ausgestellten Magic-Link-Tokens sofort invalid (90-Tage-
# Window obsolet). Pre-Live-Pflicht: 1x setzen vor erstem V8.1-Mandanten-Lead.
STRATEGAIZE_CTA_TOKEN_SECRET=GENERATE_ME_HEX_128

# Magic-Link-Expiry in Tagen. DEC-172 = 90 Tage Default, kein Single-Use in V8.1.
STRATEGAIZE_CTA_TOKEN_EXPIRY_DAYS=90

# === V9.1 Forward-Bucket-Email Inbound (SLC-V9.1-A — FEAT-075 + FEAT-076) ===
# Inbound-Vendor-Adapter-Auswahl (DEC-194). Aktuell nur 'ses-ireland'.
INBOUND_VENDOR=ses-ireland

# Shared HMAC-SHA256-Secret fuer den Inbound-Webhook /api/inbound/email. MUSS
# byte-identisch zum AWS-Secrets-Manager-Eintrag INBOUND_WEBHOOK_HMAC_SECRET
# (eu-west-1) sein, den die Lambda forward-ses-to-op-webhook beim Cold-Start liest
# (R6 HMAC-Secret-Drift — bei Mismatch 401 fuer jede Mail, kein Empfang).
# Generation: openssl rand -hex 32 . Bei Rotation beide Seiten synchron tauschen.
INBOUND_WEBHOOK_HMAC_SECRET=GENERATE_ME_HEX_64

# Catchall-Domain fuer Tenant-Routing (DEC-200). MX-Record zeigt auf
# inbound-smtp.eu-west-1.amazonaws.com. Recipient-Format bulk-<slug>@<domain>.
INBOUND_CATCHALL_DOMAIN=bulk.strategaizetransition.com

# Continuous-Cost-Caps (SLC-V9.1-B, hier vorab dokumentiert). EUR.
V91_BULK_EMAIL_DAILY_CAP_EUR=5
V91_BULK_EMAIL_MONTHLY_CAP_EUR=100
V91_BULK_EMAIL_PER_EMAIL_APPROVAL_THRESHOLD_EUR=0.5
V91_BULK_EMAIL_TRIGGER_MIN_COUNT=25

# Storage-Retention (SLC-V9.1-C, hier vorab dokumentiert). Tage.
V91_RETENTION_SOFT_DELETE_DAYS=60
V91_RETENTION_HARD_DELETE_DAYS=90
