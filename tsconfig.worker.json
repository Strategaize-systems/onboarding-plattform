{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/workers/**/*.ts",
    "src/lib/llm.ts",
    "src/lib/logger.ts",
    "src/lib/supabase/admin.ts"
  ],
  "exclude": ["node_modules"]
}
