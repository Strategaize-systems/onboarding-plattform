# === App URLs ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Supabase (Self-Hosted via Kong Gateway) ===
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here
GOTRUE_SITE_URL=http://localhost:3000

# === Database ===
POSTGRES_PASSWORD=change_me_postgres_password

# === Secrets (MUST be set before first start) ===
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS________________________________
REALTIME_SECRET=CHANGE_ME_REALTIME_SECRET_MIN_64_CHARS______________________________________________

# === LLM (AWS Bedrock — Claude Sonnet 4.6) ===
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=eu-central-1

# === Whisper — Speech-to-Text (V2) ===
# Adapter-Pattern DEC-018. Optionen: local (self-hosted), azure (Azure Speech EU)
# WHISPER_PROVIDER=local
# WHISPER_URL=http://localhost:9000
# WHISPER_MODEL=medium
# NEXT_PUBLIC_WHISPER_ENABLED=true

# === SMTP (Required for GoTrue invite emails) ===
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@strategaize.com

# === Seed-User (SLC-002b) ===
# Wird nur von scripts/seed-admin.mjs gelesen. In .env.local NICHT setzen
# (lokale Dev-DB braucht keinen Seed). Auf Hetzner im app-Container setzen
# und EINMAL pro Deploy "npm run seed:admin" ausfuehren. Rotation per
# Container-Exec + supabase.auth.admin.updateUserById, siehe docs/RUNBOOK.md.
# SEED_ADMIN_EMAIL=admin@strategaizetransition.com
# SEED_ADMIN_PASSWORD=change_me_strong_password
# SEED_DEMO_TENANT_ADMIN_EMAIL=demo-admin@strategaizetransition.com
# SEED_DEMO_TENANT_ADMIN_PASSWORD=change_me_strong_password
